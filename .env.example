# ─────────────────────────────────────────────────────────────
#  EquiBharat – Environment Variables Template
#  Copy this file to .env (or .env.local for local dev) and
#  fill in the real values. Never commit the filled file.
# ─────────────────────────────────────────────────────────────

# MySQL / MariaDB database (Hostinger / any MySQL 8 server)
MYSQL_HOST=your-db-host
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=your-db-name
# Optional – defaults to 3306
MYSQL_PORT=3306

# Public base URL of the deployed app (used for OG / sitemap)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Node environment (set automatically by most platforms)
# NODE_ENV=production
